cursor-style = "block"
cursor-style-blink = "false"
font-family = "Menlo Regular"
font-size = "13"
link-url = "true"
macos-non-native-fullscreen = "padded-notch"
macos-option-as-alt = "true"
shell-integration-features = "no-cursor"
theme = "iTerm2 Default"
window-padding-x = "4"
window-padding-y = "4"
